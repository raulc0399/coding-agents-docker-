#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
source "${SCRIPT_DIR}/lib/env_mounts.sh"

COMPOSE_FILE="${SCRIPT_DIR}/claude/docker-compose.yml"
HOST_WORKDIR="$(pwd)"
PROJECT_NAME="$(basename "${HOST_WORKDIR}")"
CONTAINER_WORKDIR="/workspace/${PROJECT_NAME}"

# Build /dev/null overlay mounts for secret files
ENV_MOUNTS=()
env_null_mounts "${HOST_WORKDIR}" ENV_MOUNTS
CONFIG_MOUNT=()
agent_config_mount_args "${HOME}/.claude" "/home/agent/.claude" CONFIG_MOUNT
STATE_MOUNT=()
agent_config_file_mount_args "${HOME}/.claude.json" "/home/agent/.claude.json" STATE_MOUNT
AGENT_ARGS=()
agent_instructions_args "${HOST_WORKDIR}" "/home/agent/.claude/CLAUDE.md" AGENT_ARGS

export HOST_UID="$(id -u)"
export HOST_GID="$(id -g)"
export HOST_WORKDIR
export CONTAINER_WORKDIR

docker compose -f "${COMPOSE_FILE}" run --rm --name d-claude \
  "${ENV_MOUNTS[@]+"${ENV_MOUNTS[@]}"}" \
  "${CONFIG_MOUNT[@]+"${CONFIG_MOUNT[@]}"}" \
  "${STATE_MOUNT[@]+"${STATE_MOUNT[@]}"}" \
  "${AGENT_ARGS[@]+"${AGENT_ARGS[@]}"}" \
  claude
