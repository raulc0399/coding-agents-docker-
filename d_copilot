#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
source "${SCRIPT_DIR}/lib/env_mounts.sh"

COMPOSE_FILE="${SCRIPT_DIR}/copilot/docker-compose.yml"
HOST_WORKDIR="$(pwd)"

# Build /dev/null overlay mounts for secret files
ENV_MOUNTS=()
env_null_mounts "${HOST_WORKDIR}" ENV_MOUNTS
CONFIG_MOUNT=()
agent_config_mount_args "${HOME}/.copilot" "/home/agent/.copilot" CONFIG_MOUNT
AGENT_ARGS=()
agent_instructions_args "${HOST_WORKDIR}" "/home/agent/.copilot/copilot-instructions.md" AGENT_ARGS

export HOST_UID="$(id -u)"
export HOST_GID="$(id -g)"
export HOST_WORKDIR

docker compose -f "${COMPOSE_FILE}" run --rm --name d-copilot \
  "${ENV_MOUNTS[@]+"${ENV_MOUNTS[@]}"}" \
  "${CONFIG_MOUNT[@]+"${CONFIG_MOUNT[@]}"}" \
  "${AGENT_ARGS[@]+"${AGENT_ARGS[@]}"}" \
  copilot
